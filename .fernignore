# This file itself — without this entry, Fern's next regen would replace
# the list below with an empty template, losing all preservation rules.
.fernignore

# Hand-written high-level wrapper around the generated IsloApiClient
src/Islo.ts
Islo.ts

# Hand-edited so all snippets reference the `Islo` wrapper instead of
# the generated `IsloApiClient`. Fern's TS generator can't redirect
# snippets to a hand-written class (Python/Go can; TS cannot — see
# https://buildwithfern.com/learn/sdks/generators/typescript/configuration).
README.md

# Hand-written extensions (auth/token providers, etc.)
src/custom/

# Customized to re-export hand-written wrappers
src/index.ts

# Hand-written TypeScript compiler config used by CI typecheck
tsconfig.json

# Hand-written release workflow that fires after a Fern PR merges:
# builds, publishes to npm via Trusted Publishing, and pushes the
# v<version> tag.
.github/workflows/release.yml
